# See root .env.example for full documentation of all variables.

# Required
PG_CONNECTION_STRING=postgres://postgres:postgres@localhost:5432/rudel
BETTER_AUTH_SECRET=

# Local frontend origin used for auth links. Dev CORS/trusted origins include
# localhost and 127.0.0.1 on ports 4011-4015 by default.
# ALLOWED_ORIGIN=http://localhost:4011
# TRUSTED_ORIGINS=http://localhost:4011,http://127.0.0.1:4011,http://localhost:4015

# ClickHouse (get hosted credentials at https://obsessiondb.com)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Slack notifications (optional)
# SLACK_WEBHOOK_URL=

# CLI device-code browser verification URL.
# CLI_DEVICE_VERIFICATION_URL=http://localhost:4011/device

# Optional private alias login for application review accounts.
# YC_LOGIN_PASSWORD_HASH must be a better-auth password hash, not plaintext.
# YC_LOGIN_ALLOWED_EMAILS=
# YC_LOGIN_TARGET_EMAIL=
# YC_LOGIN_PASSWORD_HASH=

# Resend email (optional)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=     # Required to send organization invitation emails
# RESEND_AUDIENCE_ID=    # Optional: sync new signups to a Resend audience
#
# PostHog product analytics (optional)
# POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_ENABLED=false
