# See root .env.example for full documentation.

# Required for API development.
PG_CONNECTION_STRING=postgres://postgres:postgres@localhost:5432/rudel
BETTER_AUTH_SECRET=

# API URL and trusted origins.
# APP_URL=http://localhost:4010
# ALLOWED_ORIGIN=http://localhost:4011
# TRUSTED_ORIGINS=http://localhost:4011,http://127.0.0.1:4011

# OAuth providers are optional.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Optional private alias login for application review accounts.
# YC_LOGIN_ALLOWED_EMAILS=
# YC_LOGIN_TARGET_EMAIL=
# YC_LOGIN_PASSWORD_HASH=

# Resend email is optional.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Rudel <noreply@example.com>
# RESEND_AUDIENCE_ID=

# PostHog product analytics is optional.
# POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_ENABLED=false

# ClickHouse is dormant future session infrastructure for v1.
# CLICKHOUSE_URL=
# CLICKHOUSE_USERNAME=
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DB=
