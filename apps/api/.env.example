# See root .env.example for full documentation of all variables.

# Required
PG_CONNECTION_STRING=postgres://postgres:postgres@localhost:5432/rudel
BETTER_AUTH_SECRET=

# ClickHouse (get hosted credentials at https://obsessiondb.com)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Slack notifications (optional)
# SLACK_WEBHOOK_URL=

# Ingest safeguards (optional)
# INGEST_MAX_REQUEST_BYTES=5242880
# INGEST_MAX_CONTENT_BYTES=2097152
# INGEST_MAX_TOTAL_SUBAGENT_BYTES=1048576
# INGEST_MAX_SUBAGENTS=25
# INGEST_RATE_LIMIT_WINDOW_MS=60000
# INGEST_RATE_LIMIT_MAX_REQUESTS=60
# INGEST_TRANSCRIPT_RETENTION_MODE=full
# INGEST_TRANSCRIPT_RETENTION_MAX_BYTES=500000
# INGEST_SUBAGENT_RETENTION_MODE=full
# INGEST_SUBAGENT_RETENTION_MAX_BYTES=100000
