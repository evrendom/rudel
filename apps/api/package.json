{
	"name": "@rudel/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"dev:env": "doppler run --project rudel --config prd_local -- bun --watch src/index.ts",
		"backfill:session-ownership": "bun src/scripts/backfill-session-ownership.ts",
		"resolve:session-ownership": "bun src/scripts/resolve-session-ownership.ts",
		"lint": "bun ../../scripts/check-clickhouse-guardrails.ts",
		"check-types": "tsc --noEmit",
		"test": "bun test",
		"test:clickhouse": "bun test src/__tests__/clickhouse.integration.ts",
		"test:integration": "bun test ./src/__tests__/ingest-clickhouse.integration.ts ./src/__tests__/ingest-rate-limit.integration.ts ./src/__tests__/session-ingest-content.integration.ts ./src/__tests__/clickhouse.integration.ts ./src/__tests__/delete-sessions.integration.ts ./src/__tests__/session-sharing.integration.ts",
		"test:analytics": "bun test src/__tests__/analytics.integration.ts",
		"test:migrate": "bun test src/__tests__/migrate-sessions.integration.ts",
		"test:delete-sessions": "bun test src/__tests__/delete-sessions.integration.ts"
	},
	"dependencies": {
		"@better-auth/api-key": "^1.5.4",
		"@clickhouse/client-web": "^1.11.0",
		"@logtape/file": "^2.0.4",
		"@logtape/logtape": "^2.0.4",
		"@orpc/server": "latest",
		"@resvg/resvg-js": "^2.6.2",
		"@rudel/agent-adapters": "workspace:*",
		"@rudel/api-routes": "workspace:*",
		"@rudel/ch-schema": "workspace:*",
		"@rudel/sql-schema": "workspace:*",
		"better-auth": "^1.5.4",
		"drizzle-orm": "0.45.1",
		"posthog-node": "^5.8.0",
		"postgres": "^3.4.5",
		"resend": "^6.9.3"
	},
	"devDependencies": {
		"@rudel/typescript-config": "workspace:*",
		"bun-types": "latest",
		"typescript": "5.9.2"
	}
}
