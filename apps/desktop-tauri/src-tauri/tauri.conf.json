{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Rudel Desktop",
	"version": "0.0.0",
	"identifier": "com.rudel.desktop",
	"build": {
		"frontendDist": "../static"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Rudel Desktop",
				"width": 1200,
				"height": 820
			}
		],
		"security": {
			"capabilities": ["default"]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all"
	}
}
