{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Nua",
	"version": "0.1.0",
	"identifier": "com.nua.desktop",
	"build": {
		"beforeDevCommand": "bun run dev:web",
		"beforeBuildCommand": "bun run build",
		"devUrl": "http://localhost:1420",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Nua",
				"hiddenTitle": true,
				"titleBarStyle": "Overlay",
				"width": 1200,
				"height": 820
			}
		],
		"security": {
			"capabilities": ["default"]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"macOS": {
			"signingIdentity": "-"
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEQkRENzlCQkE5QjQ5RgpSV1NmdEttN2VkM2JDRTlHVXpISm5IUHQxanRGa2NJdlFCQ1RQMHBPR3JseC9Tb3JSeWVETHVVSwo=",
			"endpoints": [
				"https://github.com/evrendom/nua-releases/releases/latest/download/latest.json"
			],
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
