# Rudel Desktop environment
#
# Copy this file to .env and fill in local values. V1 Skill Blueprint
# development requires Postgres for the API. ClickHouse is dormant future
# session infrastructure and is intentionally not required for v1.

# Postgres connection string for API development.
PG_CONNECTION_STRING=postgres://postgres:postgres@localhost:5432/rudel

# Auth secret used by better-auth for signing tokens/cookies.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# API base URL. Default: http://localhost:4010
# APP_URL=http://localhost:4010

# Desktop/web development origins trusted by the API.
# ALLOWED_ORIGIN=http://localhost:4011
# TRUSTED_ORIGINS=http://localhost:4011,http://127.0.0.1:4011

# OAuth providers are optional for local development.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Resend email integration is optional.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Rudel <noreply@example.com>
# RESEND_AUDIENCE_ID=

# PostHog product analytics is optional and should stay disabled locally unless
# instrumentation is being tested intentionally.
# POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_ENABLED=false

# ClickHouse is future paid session infrastructure. Do not require these values
# for v1 Skill Blueprint development or default verification.
# CLICKHOUSE_URL=
# CLICKHOUSE_USERNAME=
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DB=
