{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"globalPassThroughEnv": [
		"PG_CONNECTION_STRING",
		"BETTER_AUTH_SECRET",
		"APP_URL",
		"ALLOWED_ORIGIN",
		"TRUSTED_ORIGINS"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"//#lint": {},
		"test": {},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
