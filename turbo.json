{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"//#lint": {},
		"test": {},
		"test:integration": {},
		"dev": {
			"cache": false,
			"persistent": true,
			"passThroughEnv": [
				"PG_CONNECTION_STRING",
				"CLICKHOUSE_URL",
				"CLICKHOUSE_USER",
				"CLICKHOUSE_USERNAME",
				"CLICKHOUSE_PASSWORD",
				"CLICKHOUSE_DB"
			]
		}
	}
}
