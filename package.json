{
	"name": "rudel-monorepo",
	"private": true,
	"license": "MIT",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "bun run lint:biome && bun run lint:eslint",
		"lint:biome": "biome check .",
		"lint:biome:fix": "biome check --write .",
		"lint:eslint": "node ./scripts/check-eslint-gate.mjs",
		"lint:eslint:baseline": "node ./scripts/check-eslint-gate.mjs --write-baseline",
		"lint:eslint:fix": "eslint . --fix",
		"lint:fix": "bun run lint:biome:fix && bun run lint:eslint:fix",
		"format": "biome format --write .",
		"check-types": "turbo run check-types",
		"test": "turbo run test",
		"test:env": "doppler run --project rudel --config ci -- bun run test",
		"verify:ci": "bun run lint && turbo run check-types test build",
		"verify": "doppler run --project rudel --config ci -- bun run verify:ci",
		"release:cli": "bun run ./scripts/release-cli.ts",
		"deploy": "turbo run build",
		"dev:local": "bash scripts/dev-local.sh",
		"infra:up": "docker compose up -d",
		"infra:down": "docker compose down",
		"chkit:link": "bun scripts/chkit-link.ts link",
		"chkit:unlink": "bun scripts/chkit-link.ts unlink"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.0",
		"@eslint/js": "9.39.1",
		"eslint": "9.39.1",
		"turbo": "^2.8.9",
		"typescript": "5.9.2",
		"typescript-eslint": "8.57.0"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"overrides": {
		"chkit": "0.1.0-beta.16",
		"@chkit/core": "0.1.0-beta.16",
		"@chkit/clickhouse": "0.1.0-beta.16",
		"@chkit/codegen": "0.1.0-beta.16",
		"@chkit/plugin-backfill": "0.1.0-beta.16",
		"@chkit/plugin-codegen": "0.1.0-beta.16",
		"@chkit/plugin-obsessiondb": "0.1.0-beta.16",
		"@chkit/plugin-pull": "0.1.0-beta.16"
	},
	"dependencies": {
		"postgres": "^3.4.8"
	}
}
