{
	"name": "rudel-desktop",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "turbo run build",
		"build:desktop": "turbo run build --filter=@rudel/desktop",
		"build:api": "turbo run build --filter=@rudel/api",
		"dev": "turbo run dev --filter=@rudel/desktop --filter=@rudel/api",
		"dev:desktop": "turbo run dev --filter=@rudel/desktop",
		"dev:api": "turbo run dev --filter=@rudel/api",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"check-types": "turbo run check-types",
		"test": "turbo run test",
		"verify": "turbo run lint check-types test build",
		"verify:mlp": "turbo run lint check-types test build --filter=@rudel/desktop --filter=@rudel/api --filter=@rudel/skill-schema --filter=@rudel/skill-compiler",
		"chkit:link": "bun scripts/chkit-link.ts link",
		"chkit:unlink": "bun scripts/chkit-link.ts unlink"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.0",
		"turbo": "^2.8.9",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"overrides": {
		"chkit": "0.1.0-beta.16",
		"@chkit/core": "0.1.0-beta.16",
		"@chkit/clickhouse": "0.1.0-beta.16",
		"@chkit/codegen": "0.1.0-beta.16",
		"@chkit/plugin-backfill": "0.1.0-beta.16",
		"@chkit/plugin-codegen": "0.1.0-beta.16",
		"@chkit/plugin-obsessiondb": "0.1.0-beta.16",
		"@chkit/plugin-pull": "0.1.0-beta.16"
	},
	"dependencies": {
		"postgres": "^3.4.8"
	}
}
